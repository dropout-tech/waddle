# Skip ALL dependency lifecycle scripts (preinstall / install / postinstall)
# during pnpm install. None of our deps actually need them at install time:
#   - sharp: not used at runtime (images: { unoptimized: true })
#   - unrs-resolver: ESLint resolver with a JS fallback
#   - any other native binding: we don't import them
# This avoids pnpm 10's strict-build-scripts behavior, which otherwise exits
# with ERR_PNPM_IGNORED_BUILDS and fails the Zeabur build. Note this only
# affects DEPENDENCY scripts — our own package.json scripts (build / dev /
# lint / start) are run via `pnpm <name>` and are unaffected.
ignore-scripts=true

# Hoist sharp + its platform-specific binary packages to the top-level
# node_modules so Next.js can resolve them when it tries to. Belt-and-
# suspenders alongside `ignore-scripts` so the binary itself, when present,
# is in a path that survives Zeabur's Linux layout.
public-hoist-pattern[]=*sharp*
public-hoist-pattern[]=@img/*
