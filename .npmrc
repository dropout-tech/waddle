# Hoist sharp + its platform-specific binary packages (e.g. @img/sharp-linux-x64)
# to the top-level node_modules so Next.js can resolve them at runtime. Without
# this, pnpm's default isolated layout puts them in a nested .pnpm path that
# the Zeabur Linux builder occasionally can't follow, surfacing as
# "sharp: Could not load the sharp module" during `next build` even though
# images: { unoptimized: true } means sharp isn't actually used at runtime.
#
# Scoped to *sharp* only — not changing node-linker — so local pnpm installs
# stay on the default isolated layout.
public-hoist-pattern[]=*sharp*
public-hoist-pattern[]=@img/*
