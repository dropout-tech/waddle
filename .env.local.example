# ─────────────────────────────────────────────────────────
# Supabase
# Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# (Optional) Service role key — only used in server-side admin scripts.
# DO NOT expose this in client code.
# SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────
# Google OAuth (for "Sign in with Google")
# Configure inside Supabase Dashboard → Authentication → Providers → Google
# ─────────────────────────────────────────────────────────
# (No app-side env needed — Supabase handles the OAuth round-trip.)

# ─────────────────────────────────────────────────────────
# Site URL  (used by Supabase email templates and OAuth redirect)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
